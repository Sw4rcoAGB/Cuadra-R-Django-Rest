# === Cuadra Erre - Environment Variables ===
# Copia este archivo a .env y rellena tus valores locales.
# NUNCA commitees el archivo .env al repositorio.

# Entorno: development | production
ENVIRONMENT=development

# PostgreSQL
USE_POSTGRES=True
DB_NAME=cuadra_erre
DB_USER=postgres
DB_PASSWORD=tu_password_aqui
DB_HOST=localhost
DB_PORT=5432

# Seguridad Django
DJANGO_SECRET_KEY=genera-una-clave-con-python-c-"from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

# SMTP (Gmail)
EMAIL_HOST_USER=tu_correo@gmail.com
EMAIL_HOST_PASSWORD=tu_app_password_aqui

# Frontend URL (para CORS en producción)
FRONTEND_URL=http://localhost:3000
